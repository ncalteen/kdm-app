  "scripts": {
    "build": "next build",
    "ci-test": "vitest run",
    "coverage": "make-coverage-badge --output-path ./badges/coverage.svg",
    "db:generate": "supabase gen types typescript --local > lib/database.types.ts",
    "db:migrate": "supabase migration up",
    "db:reset": "supabase db reset",
    "dev": "next dev",
    "format:check": "prettier --check '**'",
    "format:write": "prettier --write '**'",
    "integration-test": "./scripts/integration.sh",
    "lint": "eslint .",
    "start": "next start",
    "test": "vitest run",
    "all": "npm run format:write && npm run lint && npm run ci-test && npm run integration-test && npm run coverage && npm run build"
  },
