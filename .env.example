######################################################
# Public Environment Variables (Exposed Client-Side) #
######################################################
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"

# Canonical site origin used to build Stripe Checkout redirect URLs.
# REQUIRED in production deployments; if omitted the route falls back to the
# request URL, which can be influenced via the Host header.
NEXT_PUBLIC_SITE_URL=""

######################################################
#                 Database Connection                #
######################################################
POSTGRES_DATABASE="postgres"
POSTGRES_HOST="127.0.0.1"
POSTGRES_PASSWORD="postgres"
# secretlint-disable-next-line
POSTGRES_URL="postgresql://<username>:<password>@<host>:<port>/<database>"
POSTGRES_USER="postgres"

SUPABASE_SECRET_KEY=""
SUPABASE_URL="http://127.0.0.1:54321"

######################################################
#                   SMTP Connection                  #
######################################################
SMTP_USER=""
SMTP_PASS=""

######################################################
#                    OAuth Clients                   #
######################################################
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

######################################################
#                  Stripe Integration                #
######################################################
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_LANTERN=""
STRIPE_PRICE_ID_LANTERN_HOARD=""

######################################################
#                   Feature Flags                    #
######################################################
# Vercel Flags SDK signing secret. Required for the Vercel Toolbar flag-
# override discovery endpoint at `/.well-known/vercel/flags`. Generate with
# `openssl rand -base64 32`.
FLAGS_SECRET=""

# Edge Config connection string for the `subscription-management` flag's
# allowlist. Provisioned automatically when the flag is created in the
# Vercel dashboard. The allowlist itself lives under the
# `subscriptionAllowlist` key as a `string[]` of Supabase user IDs,
# lowercased emails, or the literal "*" wildcard.
EDGE_CONFIG=""

# Local development fallback for the `subscription-management` allowlist
# when EDGE_CONFIG is not set. Comma-separated list of Supabase user IDs
# / lowercased emails / "*". Ignored in production whenever EDGE_CONFIG
# is configured.
SUBSCRIPTION_ALLOWLIST=""

